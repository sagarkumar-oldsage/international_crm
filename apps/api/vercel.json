{
  "version": 2,
  "installCommand": "npm install --include=dev",
  "buildCommand": "npm run prisma:generate",
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node@3.2.26",
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ]
}