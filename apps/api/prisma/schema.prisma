generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Core user model for RBAC + profile extension in later sprints.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  fullName  String
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Mobility case supports outbound/inbound student journeys.
model MobilityCase {
  id                String   @id @default(cuid())
  studentId         String
  destination       String
  applicationStatus String
  visaStatus        String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
