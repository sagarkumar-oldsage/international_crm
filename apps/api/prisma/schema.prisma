generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  IR_DIRECTOR
  IR_COORDINATOR
  DEPARTMENT_COORDINATOR
  FACULTY_MENTOR
  ADMISSION_TEAM
  VISA_TEAM
  FINANCE_TEAM
  EVENT_MANAGER
  OUTBOUND_STUDENT
  INCOMING_STUDENT
  PARTNER_REPRESENTATIVE
}

enum ApplicationStatus {
  APPLIED
  UNDER_REVIEW
  INTERVIEW_SCHEDULED
  OFFER_RECEIVED
  CONDITIONAL_OFFER
  REJECTED
  VISA_APPROVED
  ENROLLMENT_COMPLETED
}

enum DocumentCategory {
  PASSPORT
  VISA
  MARKSHEET
  DEGREE_CERTIFICATE
  SOP
  LOR
  CV
  FINANCIAL_STATEMENT
  INSURANCE
  OFFER_LETTER
  ACCEPTANCE_LETTER
}

enum DocumentStatus {
  MISSING
  PENDING_REVIEW
  VERIFIED
  REJECTED
  EXPIRED
}

enum VisaStage {
  NOT_STARTED
  DOCUMENT_COLLECTION
  APPOINTMENT_BOOKED
  BIOMETRICS_COMPLETED
  INTERVIEW_SCHEDULED
  UNDER_PROCESS
  APPROVED
  REJECTED
}

enum MouStatus {
  DRAFT
  UNDER_REVIEW
  ACTIVE
  RENEWAL_DUE
  EXPIRED
  ARCHIVED
}

enum EventCategory {
  SEMINAR
  WEBINAR
  FDP
  WORKSHOP
  CONFERENCE
  DELEGATION_VISIT
}

enum EventStatus {
  PLANNED
  REGISTRATION_OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TicketCategory {
  VISA_ISSUE
  HOSTEL_ISSUE
  DOCUMENTATION_ISSUE
  EMERGENCY_REQUEST
  SCHOLARSHIP_QUERY
  GENERAL_SUPPORT
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  RESOLVED
  CLOSED
}

// Core user model for RBAC + profile extension in later sprints.
model User {
  id           String          @id @default(cuid())
  email        String          @unique
  fullName     String
  passwordHash String
  role         UserRole
  studentProfile StudentProfile?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model StudentProfile {
  id                     String               @id @default(cuid())
  userId                 String               @unique
  program                String
  cgpa                   Decimal              @db.Decimal(3, 2)
  languageScore          String
  destinationPreferences String[]
  budgetBand             String
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications           StudentApplication[]
  documents              StudentDocument[]
  visaCases              VisaCase[]
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
}

model StudentApplication {
  id               String            @id @default(cuid())
  studentProfileId String
  university       String
  country          String
  program          String
  status           ApplicationStatus
  deadline         DateTime
  studentProfile   StudentProfile    @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model StudentDocument {
  id               String           @id @default(cuid())
  studentProfileId String
  category         DocumentCategory
  fileName         String
  storagePath      String
  status           DocumentStatus
  expiresAt        DateTime?
  notes            String?
  studentProfile   StudentProfile   @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model VisaCase {
  id                 String       @id @default(cuid())
  studentProfileId   String
  country            String
  visaType           String
  currentStage       VisaStage
  appointmentDate    DateTime?
  biometricsDate     DateTime?
  interviewDate      DateTime?
  decisionDate       DateTime?
  notes              String?
  studentProfile     StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model PartnerUniversity {
  id                 String      @id @default(cuid())
  name               String
  country            String
  city               String
  website            String?
  contactPersonName  String
  contactPersonEmail String
  collaborationAreas String[]
  mouStatus          MouStatus
  renewalDate        DateTime?
  mobilityQuota      Int
  jointPrograms      String[]
  notes              String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

model InternationalEvent {
  id                   String        @id @default(cuid())
  title                String
  category             EventCategory
  format               String
  hostCountry          String
  venue                String
  organizer            String
  registrationDeadline DateTime?
  startDate            DateTime
  endDate              DateTime
  status               EventStatus
  capacity             Int
  registeredCount      Int
  speaker              String?
  notes                String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model SupportTicket {
  id               String         @id @default(cuid())
  studentProfileId String?
  raisedByName     String
  raisedByEmail    String
  category         TicketCategory
  subject          String
  description      String
  priority         TicketPriority
  status           TicketStatus
  assignedTeam     String?
  resolutionNotes  String?
  dueDate          DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

// Mobility case supports outbound/inbound student journeys.
model MobilityCase {
  id                String   @id @default(cuid())
  studentId         String
  destination       String
  applicationStatus String
  visaStatus        String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
