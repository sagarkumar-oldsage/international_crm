{
  "version": 2,
  "framework": "nextjs",
  "installCommand": "npm install --include=dev",
  "buildCommand": "npm run build -w apps/api && npm run build -w apps/web",
  "devCommand": "npm run dev -w apps/web",
  "outputDirectory": "apps/web/.next",
  "functions": {
    "api/v1/[...route].ts": {
      "runtime": "@vercel/node@3.2.26",
      "maxDuration": 60
    }
  }
}
